# Google Gemini (ฟรี 1,500 req/วัน)
# สมัครที่ aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# Google Service Account (Drive + Sheets)
# copy JSON key ทั้งก้อนใส่เป็น single line
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Google Sheets ID (จาก URL ของ Sheet)
SHEET_ID=1ABC...

# Weather API — เช่น OpenWeatherMap (ฟรี 1,000 req/วัน)
# สมัครที่ openweathermap.org/api
WEATHER_API_KEY=...

# พิกัดฟาร์ม (สำหรับดึงสภาพอากาศ)
FARM_LATITUDE=11.5564
FARM_LONGITUDE=104.9282
