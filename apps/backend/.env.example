# Claude API (Anthropic JS SDK)
ANTHROPIC_API_KEY=sk-ant-...

# Gemini Fallback — ฟรี 1,500 req/วัน (aistudio.google.com/app/apikey)
GEMINI_API_KEY=AIza...

# Google OAuth (สำหรับ user login — Phase 2)
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=http://localhost:3000/v1/auth/callback

# Google Service Account (Drive + Sheets)
# copy JSON key ทั้งก้อนใส่เป็น single line
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Google Sheets ID (จาก URL ของ Sheet)
SHEET_ID=1ABC...xyz

# JWT
JWT_SECRET=change-this-to-a-long-random-string-32chars
JWT_REFRESH_SECRET=another-long-random-string-32chars

# BullMQ + Redis
REDIS_URL=redis://localhost:6379

# [FUTURE] ML Microservice — ลบออกถ้าไม่ใช้ Phase 1
# ML_SERVICE_URL=http://localhost:8000

# App
PORT=3000
NODE_ENV=development
